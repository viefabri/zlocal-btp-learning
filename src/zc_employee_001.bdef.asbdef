projection;
strict ( 2 ); // Side Effectsを使用するため有効化必須
use draft;

define behavior for ZC_EMPLOYEE_001 alias Employee
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  side effects { field Salary affects field Grade, field AnnualSalary; }
}